# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME=it406-Test02-Docker-Container-2-Chana


MY_USERNAME=Chana #ใส่ชื่อผู้ใช้ของคุณ

# พอร์ตที่ใช้สำหรับบริการต่าง ๆ
HTTP_PORT=8080
PMA_PORT=3306

# พอร์ตสำหรับ Web Proxy (Nginx)
Web_Server (Nginx)= 11101
# พอร์ตสำหรับ phpMyAdmin
phpMyAdmin=11102

# DB Details
DB_USER=Chana
DB_NAME=Chana-db